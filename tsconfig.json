{
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "commonjs",
    "lib": [
      "ES2022"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "typeRoots": [
      "./node_modules/@types",
      "./@types"
    ]
  },
  "references": [
    {
      "path": "./packages/testing"
    },
    {
      "path": "./packages/shared"
    },
    {
      "path": "./packages/config"
    },
    {
      "path": "./packages/eslint-plugin"
    },
    {
      "path": "./packages/hooks"
    },
    {
      "path": "./packages/tooling"
    },
    {
      "path": "./packages/ward"
    },
    {
      "path": "./packages/orchestrator"
    },
    {
      "path": "./packages/local-eslint"
    },
    {
      "path": "./packages/mcp"
    },
    {
      "path": "./packages/server"
    },
    {
      "path": "./packages/cli"
    }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "exploratories/**/*",
    "tests/tmp/**/*",
    "jest.*.js",
    "v1/**/*"
  ],
  "extends": "./packages/eslint-plugin/configs/tsconfig.json",
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "files": []
}
