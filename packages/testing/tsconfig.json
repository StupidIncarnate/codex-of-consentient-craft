{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declarationMap": true,
    "declaration": true,
    "noEmit": false,
    "typeRoots": [
      "../../node_modules/@types",
      "../../@types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "e2e/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
