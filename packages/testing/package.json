{
  "name": "@dungeonmaster/testing",
  "version": "0.1.0",
  "description": "Testing utilities and helpers for Dungeonmaster projects",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./register-mock": {
      "source": "./src/register-mock.ts",
      "import": "./dist/register-mock.js",
      "require": "./dist/register-mock.js",
      "types": "./dist/register-mock.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/startup/*.js 2>/dev/null || true",
    "build:clean": "rm -rf dist && npm run build",
    "test": "dungeonmaster-ward --only test",
    "typecheck": "dungeonmaster-ward --only typecheck",
    "lint": "dungeonmaster-ward --only lint",
    "ward": "dungeonmaster-ward"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "typesVersions": {
    "*": {
      "register-mock": [
        "dist/register-mock.d.ts"
      ]
    }
  },
  "dependencies": {
    "msw": "^2.12.10"
  }
}
