{
  "name": "@dungeonmaster/testing",
  "version": "0.1.0",
  "description": "Testing utilities and helpers for Dungeonmaster projects",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./register-mock": {
      "source": "./src/register-mock.ts",
      "import": "./dist/src/register-mock.js",
      "require": "./dist/src/register-mock.js",
      "types": "./dist/src/register-mock.d.ts"
    },
    "./brokers/network-record/playwright": {
      "source": "./src/brokers/network-record/playwright/network-record-playwright-broker.ts",
      "import": "./dist/src/brokers/network-record/playwright/network-record-playwright-broker.js",
      "require": "./dist/src/brokers/network-record/playwright/network-record-playwright-broker.js",
      "types": "./dist/src/brokers/network-record/playwright/network-record-playwright-broker.d.ts"
    },
    "./adapters/fs/queue-metadata-read": {
      "source": "./src/adapters/fs/queue-metadata-read/fs-queue-metadata-read-adapter.ts",
      "import": "./dist/src/adapters/fs/queue-metadata-read/fs-queue-metadata-read-adapter.js",
      "require": "./dist/src/adapters/fs/queue-metadata-read/fs-queue-metadata-read-adapter.js",
      "types": "./dist/src/adapters/fs/queue-metadata-read/fs-queue-metadata-read-adapter.d.ts"
    },
    "./transformers/quest-flow-observable-seed": {
      "source": "./src/transformers/quest-flow-observable-seed/quest-flow-observable-seed-transformer.ts",
      "import": "./dist/src/transformers/quest-flow-observable-seed/quest-flow-observable-seed-transformer.js",
      "require": "./dist/src/transformers/quest-flow-observable-seed/quest-flow-observable-seed-transformer.js",
      "types": "./dist/src/transformers/quest-flow-observable-seed/quest-flow-observable-seed-transformer.d.ts"
    },
    "./transformers/quest-gate-content-seed": {
      "source": "./src/transformers/quest-gate-content-seed/quest-gate-content-seed-transformer.ts",
      "import": "./dist/src/transformers/quest-gate-content-seed/quest-gate-content-seed-transformer.js",
      "require": "./dist/src/transformers/quest-gate-content-seed/quest-gate-content-seed-transformer.js",
      "types": "./dist/src/transformers/quest-gate-content-seed/quest-gate-content-seed-transformer.d.ts"
    },
    "./jest-config-base": "./jest-config-base.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/src/startup/*.js 2>/dev/null || true",
    "build:clean": "rm -rf dist && npm run build",
    "test": "dungeonmaster-ward --only test",
    "typecheck": "dungeonmaster-ward --only typecheck",
    "lint": "dungeonmaster-ward --only lint",
    "ward": "dungeonmaster-ward"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "typesVersions": {
    "*": {
      "register-mock": [
        "dist/src/register-mock.d.ts"
      ],
      "brokers/network-record/playwright": [
        "dist/src/brokers/network-record/playwright/network-record-playwright-broker.d.ts"
      ],
      "adapters/fs/queue-metadata-read": [
        "dist/src/adapters/fs/queue-metadata-read/fs-queue-metadata-read-adapter.d.ts"
      ],
      "transformers/quest-flow-observable-seed": [
        "dist/src/transformers/quest-flow-observable-seed/quest-flow-observable-seed-transformer.d.ts"
      ],
      "transformers/quest-gate-content-seed": [
        "dist/src/transformers/quest-gate-content-seed/quest-gate-content-seed-transformer.d.ts"
      ]
    }
  },
  "dependencies": {
    "msw": "^2.12.10"
  }
}
