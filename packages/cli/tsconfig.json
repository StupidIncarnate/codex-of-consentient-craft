{
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "./dist",
    "declarationMap": true,
    "declaration": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "module": "commonjs",
    "moduleResolution": "node",
    "typeRoots": [
      "../../node_modules/@types",
      "../../@types"
    ]
  },
  "references": [
    {
      "path": "../orchestrator"
    },
    {
      "path": "../server"
    },
    {
      "path": "../shared"
    },
    {
      "path": "../testing"
    }
  ],
  "include": [
    "src/**/*",
    "bin/**/*",
    "test/**/*",
    "*.ts"
  ],
  "extends": "../../tsconfig.json",
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  }
}
