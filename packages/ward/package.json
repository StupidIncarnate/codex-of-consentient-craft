{
  "name": "@dungeonmaster/ward",
  "version": "0.1.0",
  "description": "Structured lint/typecheck/test runner with tiered drill-down output",
  "bin": {
    "dungeonmaster-ward": "./dist/bin/ward-entry.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/src/startup/*.js dist/bin/*.js 2>/dev/null || true",
    "build:clean": "rm -rf dist && npm run build",
    "test": "dungeonmaster-ward --only test",
    "lint": "dungeonmaster-ward --only lint",
    "typecheck": "dungeonmaster-ward --only typecheck",
    "ward": "dungeonmaster-ward"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "README.md"
  ],
  "keywords": [
    "ward",
    "lint",
    "typecheck",
    "test",
    "runner"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@dungeonmaster/testing": "*"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-eslint-comments": "^3.2.0"
  },
  "dependencies": {
    "@dungeonmaster/shared": "*",
    "zod": "^3.25.76"
  }
}
