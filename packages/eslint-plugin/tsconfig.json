{
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "declarationMap": true,
    "declaration": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "typeRoots": [
      "../../node_modules/@types",
      "../../@types"
    ],
    "paths": {
      "@dungeonmaster/eslint-plugin": [
        "./src/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../shared"
    },
    {
      "path": "../testing"
    }
  ],
  "include": [
    "src/**/*"
  ],
  "extends": "../../tsconfig.json"
}
