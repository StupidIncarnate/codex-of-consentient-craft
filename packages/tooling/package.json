{
  "name": "@dungeonmaster/tooling",
  "version": "1.0.0",
  "description": "Development tools for code quality analysis",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "bin": {
    "detect-duplicate-primitives": "./dist/bin/detect-duplicate-primitives.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/src/startup/*.js 2>/dev/null || true",
    "build:clean": "rm -rf dist && npm run build",
    "test": "dungeonmaster-ward --only test",
    "test:unit": "jest --testPathIgnorePatterns='\\.integration\\.'",
    "typecheck": "dungeonmaster-ward --only typecheck",
    "lint": "dungeonmaster-ward --only lint",
    "ward": "dungeonmaster-ward",
    "detect-duplicates": "tsx src/index.ts"
  },
  "dependencies": {
    "@dungeonmaster/shared": "*",
    "glob": "^10.3.10",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@dungeonmaster/testing": "*",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
