#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const os = require('os');
const http = require('http');

const queueDir = process.env.FAKE_CLAUDE_QUEUE_DIR;

if (!queueDir) {
    process.stderr.write('FAKE_CLAUDE_QUEUE_DIR env var is not set\n');
    process.exit(1);
}

// Cross-test isolation: each test scopes its queue under a subdirectory keyed by the
// spawning process's cwd (the guild path). The orchestrator spawns this fake CLI with
// `cwd: guildPath`, so different specs (with different guild paths) get isolated queues
// even though all tests share the same root FAKE_CLAUDE_QUEUE_DIR. A leftover loop from
// a prior spec cannot consume a queued response from the current spec.
const encodeCwd = (cwd) => cwd.replace(/[^A-Za-z0-9._-]/g, '_');
const scopedQueueDir = path.join(queueDir, '__by_cwd__', encodeCwd(process.cwd()));

// Prefer the cwd-scoped queue when it has files; fall back to the root queue for callers
// that don't scope (e.g. legacy harness calls without a guild path).
const readQueueFiles = (dir) => {
    try {
        return fs.readdirSync(dir)
            .filter((f) => f.endsWith('.json') && f !== 'metadata.json')
            .sort();
    } catch {
        return null;
    }
};

const scopedFiles = readQueueFiles(scopedQueueDir);
let activeQueueDir;
let files;
if (scopedFiles && scopedFiles.length > 0) {
    activeQueueDir = scopedQueueDir;
    files = scopedFiles;
} else {
    const rootFiles = readQueueFiles(queueDir);
    if (rootFiles === null) {
        process.stderr.write(`Failed to read queue directory: ${queueDir}\n`);
        process.exit(1);
    }
    activeQueueDir = queueDir;
    files = rootFiles;
}

if (files.length === 0) {
    process.stderr.write('Fake Claude CLI: queue is empty — no response files found. Did you call queueClaudeResponse() in your test?\n');
    process.exit(1);
}

// Atomic claim: when N parallel agents spawn and read the same dir snapshot,
// they all see the same files[0]. Without atomic ownership, two processes can
// both fs.readFileSync the same file (its inode survives unlink while open),
// then duplicate-process the same response — manifesting in tests as wrong
// agent counts under load. Use renameSync (atomic on POSIX within same dir)
// to claim a unique file before reading.
const claimFile = (filePath) => {
    const claimPath = `${filePath}.claimed-${process.pid}-${Date.now()}`;
    try {
        fs.renameSync(filePath, claimPath);
        return claimPath;
    } catch (err) {
        if (err.code === 'ENOENT') {
            return null;
        }
        throw err;
    }
};

let claimedPath = null;
for (const file of files) {
    const candidate = path.join(activeQueueDir, file);
    const claimed = claimFile(candidate);
    if (claimed !== null) {
        claimedPath = claimed;
        break;
    }
}

if (claimedPath === null) {
    process.stderr.write('Fake Claude CLI: all queue files were claimed by other processes — increase queue depth or check test setup\n');
    process.exit(1);
}

const raw = fs.readFileSync(claimedPath, 'utf-8');
const response = JSON.parse(raw);

// Remove the consumed file from the queue
fs.unlinkSync(claimedPath);

const lines = response.lines || [];
const exitCode = response.exitCode ?? 0;
const delayMs = response.delayMs ?? 10;
const sessionId = response.sessionId || null;
// E2E dispatch-loop driver fields (see claude-queue-response-contract).
const signalBack = response.signalBack || null;
const hang = response.hang === true;

// Extract user message from -p argument (matches real Claude CLI behavior)
const pFlagIndex = process.argv.indexOf('-p');
const userMessage = pFlagIndex !== -1 && pFlagIndex + 1 < process.argv.length
    ? process.argv[pFlagIndex + 1]
    : null;

// The Node dispatcher hands each child a task prompt containing questId + workItemId literally
// (build-task-prompt-layer-broker). Parse the first `<key>: "<value>"` occurrence — both the
// get-agent-prompt block and the signal-back block repeat the same values, so the first match wins.
const parsePromptId = (key) => {
    if (!userMessage) return null;
    const match = userMessage.match(new RegExp(`${key}\\s*:\\s*"([^"]+)"`));
    return match ? match[1] : null;
};

// The server binds to environmentStatics.hostname ('dungeonmaster.localhost'), NOT a raw loopback
// IP — posting to 127.0.0.1 hits the wrong address family (IPv4 vs IPv6) and gets ECONNREFUSED.
// Resolving the SAME hostname both sides bind/fetch through keeps them aligned regardless of the
// host's /etc/hosts configuration.
const SIGNAL_BACK_HOST = 'dungeonmaster.localhost';

// POST the env-gated HTTP signal-back endpoint and AWAIT the full response so the operations relay
// advances (work item terminal + operation complete + next work item created) BEFORE this child
// exits — the dispatch loop awaits the exit and re-scans, and an in_progress work item seen at scan
// is treated as orphaned. Using the node `http` module (not global fetch) keeps this independent of
// the runtime Node version.
function postSignalBack() {
    return new Promise((resolve) => {
        const questId = parsePromptId('questId');
        const workItemId = parsePromptId('workItemId');
        const port = process.env.DUNGEONMASTER_PORT;
        if (!questId || !workItemId || !port) {
            process.stderr.write(
                `Fake Claude CLI: cannot signal-back (questId=${questId}, workItemId=${workItemId}, port=${port})\n`,
            );
            resolve();
            return;
        }
        const payload = JSON.stringify({
            workItemId,
            signal: 'complete',
            operationStatus: signalBack.operationStatus,
        });
        const req = http.request(
            {
                host: SIGNAL_BACK_HOST,
                port: Number(port),
                path: `/api/quests/${questId}/signal-back`,
                method: 'POST',
                headers: {
                    'content-type': 'application/json',
                    'content-length': Buffer.byteLength(payload),
                },
            },
            (res) => {
                // Drain the body so the socket settles before the process exits.
                res.on('data', () => {});
                res.on('end', () => resolve());
            },
        );
        req.on('error', (err) => {
            process.stderr.write(`Fake Claude CLI: signal-back POST failed: ${String(err)}\n`);
            resolve();
        });
        req.write(payload);
        req.end();
    });
}

// Write JSONL session file (mimics real Claude CLI writing ~/.claude/projects/...)
function writeJsonlSessionFile() {
    if (!sessionId) return;

    const homeDir = os.homedir();
    const projectPath = process.cwd();
    const encodedPath = projectPath.replace(/\//g, '-');
    const jsonlDir = path.join(homeDir, '.claude', 'projects', encodedPath);
    const jsonlPath = path.join(jsonlDir, `${sessionId}.jsonl`);

    fs.mkdirSync(jsonlDir, {recursive: true});

    // Build JSONL entries using same data structures as stream-json stubs
    const entries = [];

    // Add user message entry (same shape as real Claude JSONL)
    if (userMessage) {
        entries.push(JSON.stringify({
            type: 'user',
            message: {role: 'user', content: userMessage},
        }));
    }

    // Add assistant AND user entries from stream lines (filter out system/result types).
    // Real Claude CLI writes BOTH assistant content AND user/tool_result lines to the
    // session JSONL — when the web's subscribe-quest replays, it needs both halves to
    // pair tool_use with its tool_result. Filtering out user lines here would mean
    // file-replay shows tool_uses with no results paired (orphan render), even though
    // streaming delivered them correctly. This breaks stream-vs-replay parity.
    for (const line of lines) {
        try {
            const parsed = JSON.parse(line);
            if (parsed.type === 'assistant' || parsed.type === 'user') {
                entries.push(line);
            }
        } catch {
            // Skip unparseable lines
        }
    }

    // For --resume flows, append to existing file; otherwise overwrite
    const isResume = process.argv.includes('--resume');
    if (isResume) {
        fs.appendFileSync(jsonlPath, entries.join('\n') + '\n');
    } else {
        fs.writeFileSync(jsonlPath, entries.join('\n') + '\n');
    }
}

// Runs once every queued stream line has been emitted. In hang mode the process blocks forever
// (init line already emitted so sessionId stamps). Otherwise it optionally signals back (awaited),
// writes the JSONL session file, and exits.
async function finish() {
    if (hang) {
        // Keep the event loop alive indefinitely — a restart spec kills this child.
        setInterval(() => {}, 1 << 30);
        return;
    }

    if (signalBack) {
        await postSignalBack();
    }

    writeJsonlSessionFile();
    process.exit(exitCode);
}

let index = 0;

function writeLine() {
    if (index >= lines.length) {
        void finish();
        return;
    }

    process.stdout.write(lines[index] + '\n');
    index++;

    if (index >= lines.length) {
        void finish();
    } else {
        setTimeout(writeLine, delayMs);
    }
}

writeLine();
