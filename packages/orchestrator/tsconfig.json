{
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./",
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "declaration": true,
    "declarationMap": true,
    "typeRoots": [
      "../../node_modules/@types",
      "../../@types"
    ]
  },
  "references": [
    {
      "path": "../config"
    },
    {
      "path": "../shared"
    },
    {
      "path": "../testing"
    }
  ],
  "include": [
    "src/**/*",
    "src/.test-tmp/**/*",
    "test/**/*",
    "*.ts"
  ],
  "extends": "../../tsconfig.json"
}
