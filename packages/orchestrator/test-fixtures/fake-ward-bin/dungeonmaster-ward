#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

// Handle "detail <runId> [--json]" subcommand
const subcommand = process.argv[2];
if (subcommand === 'detail') {
    const runId = process.argv[3];
    if (!runId) {
        process.stderr.write('Usage: dungeonmaster-ward detail <run-id> [--json]\n');
        process.exit(1);
    }
    const cwd = process.cwd();
    const resultFile = path.join(cwd, '.ward', `run-${runId}.json`);
    try {
        const contents = fs.readFileSync(resultFile, 'utf-8');
        // Use writeFileSync to fd 1 (stdout) to ensure flush
        fs.writeFileSync(1, contents);
        process.exit(0);
    } catch {
        process.stderr.write(`Ward result file not found: ${resultFile}\n`);
        process.exit(1);
    }
}

const queueDir = process.env.FAKE_WARD_QUEUE_DIR;

if (!queueDir) {
    process.stderr.write('FAKE_WARD_QUEUE_DIR env var is not set\n');
    process.exit(1);
}

// Cross-test isolation: each test scopes its queue under a subdirectory keyed by the
// spawning process's cwd (the guild path). The orchestrator spawns ward with
// `cwd: guildPath`, so different specs (with different guild paths) get isolated queues
// even though all tests share the same root FAKE_WARD_QUEUE_DIR.
const encodeCwd = (cwd) => cwd.replace(/[^A-Za-z0-9._-]/g, '_');
const scopedQueueDir = path.join(queueDir, '__by_cwd__', encodeCwd(process.cwd()));

const readQueueFiles = (dir) => {
    try {
        return fs.readdirSync(dir)
            .filter((f) => f.endsWith('.json') && f !== 'metadata.json')
            .sort();
    } catch {
        return null;
    }
};

const scopedFiles = readQueueFiles(scopedQueueDir);
let activeQueueDir;
let files;
if (scopedFiles && scopedFiles.length > 0) {
    activeQueueDir = scopedQueueDir;
    files = scopedFiles;
} else {
    const rootFiles = readQueueFiles(queueDir);
    if (rootFiles === null) {
        process.stderr.write(`Failed to read ward queue directory: ${queueDir}\n`);
        process.exit(1);
    }
    activeQueueDir = queueDir;
    files = rootFiles;
}

if (files.length === 0) {
    process.stderr.write('Fake ward CLI: queue is empty — no response files found.\n');
    process.exit(1);
}

// Atomic claim — see fake claude CLI for full rationale. Without atomic
// ownership, parallel ward invocations can both read the same queue file.
const claimFile = (filePath) => {
    const claimPath = `${filePath}.claimed-${process.pid}-${Date.now()}`;
    try {
        fs.renameSync(filePath, claimPath);
        return claimPath;
    } catch (err) {
        if (err.code === 'ENOENT') {
            return null;
        }
        throw err;
    }
};

let claimedPath = null;
for (const file of files) {
    const candidate = path.join(activeQueueDir, file);
    const claimed = claimFile(candidate);
    if (claimed !== null) {
        claimedPath = claimed;
        break;
    }
}

if (claimedPath === null) {
    process.stderr.write('Fake ward CLI: all queue files were claimed by other processes\n');
    process.exit(1);
}

const raw = fs.readFileSync(claimedPath, 'utf-8');
const response = JSON.parse(raw);

// Remove the consumed file from the queue
fs.unlinkSync(claimedPath);

const exitCode = response.exitCode ?? 0;
const runId = response.runId || `fake-${Date.now()}`;
const wardResultJson = response.wardResultJson || null;

// Write ward result JSON file to <cwd>/.ward/run-<runId>.json
if (wardResultJson) {
    const cwd = process.cwd();
    const wardDir = path.join(cwd, '.ward');
    fs.mkdirSync(wardDir, { recursive: true });
    fs.writeFileSync(
        path.join(wardDir, `run-${runId}.json`),
        JSON.stringify(wardResultJson),
    );
}

// Write optional output lines before the run ID (for streaming tests)
// delayMs allows e2e tests to wait for browser WS reconnection before output arrives
const outputLines = response.outputLines || [];
const delayMs = response.delayMs || 0;

const writeOutputAndExit = () => {
    for (const line of outputLines) {
        fs.writeFileSync(1, `${line}\n`);
    }

    // Write run ID to stdout (ward output format: "run: <id>")
    // Use fs.writeFileSync(1, ...) to ensure synchronous write to stdout fd
    fs.writeFileSync(1, `run: ${runId}\n`);

    process.exit(exitCode);
};

if (delayMs > 0) {
    setTimeout(writeOutputAndExit, delayMs);
} else {
    writeOutputAndExit();
}
